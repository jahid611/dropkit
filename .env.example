# DropKit — variables d'environnement
# Copier en .env (jamais committé) et remplir avec vos vraies valeurs.

# Connexion Postgres (Supabase → Settings → Database → Connection string)
# URL de runtime (pooler, port 6543, pgbouncer) :
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# URL directe (migrations / prisma db push, port 5432) :
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase Storage — upload d'images (bucket public "dropkit")
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<votre clé service_role>"

# Optionnel — envoi réel des emails de fin de drop (sinon mode simulation)
# RESEND_API_KEY=
# RESEND_FROM="DropKit <onboarding@resend.dev>"
